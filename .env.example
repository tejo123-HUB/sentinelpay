# Copy this file to .env and adjust as needed.

# HTTP server port
PORT=3000

# Path to the SQLite database file (created automatically on first run)
DB_PATH=./sentinelpay.db

# ML serving mode: "local" runs inference in-process (default), "python-service" calls
# ml/serve.py over HTTP, "vertex" genuinely calls a real Vertex AI Endpoint (server/ml/mlClient.js's
# scoreViaVertexAi, 24 July 2026 -- see architecture.md Section 9). Provisioning the Vertex AI
# Endpoint itself (uploading/deploying a model) is outside this repo's scope.
ML_SERVING_MODE=local
ML_SERVICE_URL=http://127.0.0.1:8000/predict

# Only used when ML_SERVING_MODE=vertex. All three are required; the resource name this builds is
# projects/{VERTEX_AI_PROJECT_ID}/locations/{VERTEX_AI_LOCATION}/endpoints/{VERTEX_AI_ENDPOINT_ID}.
# Auth is via GOOGLE_APPLICATION_CREDENTIALS below, not an API key.
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=
VERTEX_AI_ENDPOINT_ID=

# Structuring background job interval, in milliseconds
STRUCTURING_JOB_INTERVAL_MS=7000

# Shared secret required on every API request (header: X-API-Key; the /ws WebSocket takes it as
# ?apiKey=... instead, since browsers can't set custom headers on a WS handshake). Added during a
# full-project security review: previously nothing protected POST /transaction or the read
# endpoints (GET /transactions, /alerts, /audit/summary), so anyone who could reach the server
# could read every user's transaction history (sender/receiver IDs, exact GPS location, amount,
# device ID) and inject arbitrary transactions.
# PROD: the dashboard would sit behind real user auth (SSO/session), with a backend-for-frontend
# holding this key server-side. DEMO: there's no login system in this hackathon build, so
# server/index.js hands the key straight to the dashboard page at load time — see
# server/middleware/apiKeyAuth.js for the full explanation of that trade-off.
# Leave unset for pure localhost demo use — an insecure, loudly-warned built-in default applies
# (server/middleware/apiKeyAuth.js's DEFAULT_DEV_API_KEY), shared automatically with the simulator
# and benchmark scripts so nothing extra needs configuring for a same-machine demo. Set a real
# value before running this anywhere reachable beyond localhost, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
API_KEY=

# Optional additional keys for role-based access control (Section 16, Category 20). Unset by
# default -- only API_KEY (admin) works, exactly as before. Set these to turn on real,
# server-enforced role restrictions: a viewer key can only GET; an analyst key can also ingest
# transactions/logins/disputes/notes; only the admin key (API_KEY) can edit business_accounts,
# fraud_lists, or view the admin audit log. See server/middleware/apiKeyAuth.js for exactly which
# routes require which role.
API_KEY_ANALYST=
API_KEY_VIEWER=

# Max requests per IP per 60-second sliding window, across every route (including the WebSocket
# handshake and the dashboard-serving routes, not just the API) — server/middleware/rateLimit.js.
# /health is exempt. Default (2000) is generous enough for the simulator's continuous stream and
# the 500-request benchmark run; lower it if this is ever exposed beyond a trusted demo network.
# Set to 0 to block all non-exempt traffic outright (an explicit "0" is honored, not silently
# treated as "unset").
RATE_LIMIT_MAX_PER_MINUTE=2000

# Critical Fraud Alerts (Section 16, Category 17) -- real, working notification integrations,
# fired automatically on any Critical-severity detection (merchant takeover, suspected mule,
# blacklist hit, structuring alert) and manually testable via POST /notifications/test
# (admin role required). Every channel below is genuinely functional the moment it's
# configured; leave a channel's variables unset to skip it entirely (no error, just silently
# not sent -- see server/notifications.js).
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# SMS via Twilio's REST API (or a Twilio-compatible provider)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO_NUMBER=
# Email via a minimal built-in SMTP client (implicit TLS on SMTP_PORT, default 465 -- does not
# support STARTTLS upgrade on port 587)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Network interface to bind to. Leave unset: defaults to 127.0.0.1 (localhost only) whenever the
# insecure default API key is in use (see API_KEY above) — so a forgotten .env doesn't also mean
# this server is reachable by every other device on whatever network it's running on, e.g. a
# laptop demoed on hackathon venue WiFi. Once a real API_KEY is configured, defaults to listening
# on all interfaces as before. Set explicitly (e.g. HOST=0.0.0.0) to override either default.
HOST=

# Web Push Notifications (Partial-Feature Completion Pass) -- VAPID key pair, generated once per
# deployment via `npm run generate-vapid-keys` (server/webPush.js implements RFC 8291/8292 with
# no `web-push` dependency). Leave unset to skip Web Push entirely, same silently-skipped
# convention as every other notification channel above.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# AI Assistant (Section 26, Partial-Feature Completion Pass) -- optional. Every AI endpoint
# (POST /ai/chat, POST /ai/search, GET /ai/report, GET /ai/insights) has a real, deterministic,
# no-API-key-required implementation that is the default. Setting GEMINI_API_KEY genuinely calls
# Google's Gemini API (native fetch, no SDK dependency) for richer free-form chat/report answers,
# grounded in the same deterministic context and falling back to it on any failure -- see
# server/aiAssistant.js. Get a free key from https://aistudio.google.com/apikey. If both are set,
# Gemini is preferred; ANTHROPIC_API_KEY (Claude) works the same way as an alternative provider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=

# --- Google Cloud integrations (24 July 2026 pass) ------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS is shared by all three integrations below (Cloud Storage,
# Vertex AI, and the Cloud Spanner proof-of-concept module) -- the standard Google Cloud
# Application Default Credentials env var, pointing at a downloaded service-account JSON key
# file. Create one at https://console.cloud.google.com/iam-admin/serviceaccounts, grant it the
# role(s) each integration below needs (Storage Object Admin on the bucket; Vertex AI User on the
# endpoint; Cloud Spanner Database User on the database), and never commit the key file itself.
GOOGLE_APPLICATION_CREDENTIALS=

# Case evidence storage (server/caseEvidence.js) -- optional. With GCS_BUCKET_NAME unset (the
# default), evidence stays on the local filesystem (data/evidence/) exactly as before this
# integration existed. Setting it genuinely uploads/downloads/deletes objects in that Cloud
# Storage bucket via the official @google-cloud/storage SDK.
GCS_BUCKET_NAME=

# Cloud Spanner proof-of-concept module (server/spannerPoc.js) -- NOT this app's actual database
# (SQLite/DB_PATH above remains that). All three are required to run `npm run spanner:poc`
# (scripts/spanner_poc_demo.js), which stands up the schema, inserts one sample transaction, and
# reads it back against a real Spanner instance you've already provisioned.
SPANNER_PROJECT_ID=
SPANNER_INSTANCE_ID=
SPANNER_DATABASE_ID=
