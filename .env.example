# Copy this file to .env and adjust as needed.

# HTTP server port
PORT=3000

# Path to the SQLite database file (created automatically on first run)
DB_PATH=./sentinelpay.db

# ML serving mode: "local" calls ml/serve.py over HTTP, "vertex" calls a Vertex AI endpoint
# PROD: Vertex AI — DEMO: local
ML_SERVING_MODE=local
ML_SERVICE_URL=http://127.0.0.1:8000/predict

# Only used when ML_SERVING_MODE=vertex
VERTEX_AI_ENDPOINT_URL=
VERTEX_AI_API_KEY=

# Structuring background job interval, in milliseconds
STRUCTURING_JOB_INTERVAL_MS=7000
